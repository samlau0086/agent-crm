OUTLOOK_OAUTH_SCOPE="https://graph.microsoft.com/Mail.ReadWrite https://graph.microsoft.com/Mail.Send offline_access"
ALLOW_PRIVATE_WEBHOOK_URLS="false"
WAIT_FOR_DATABASE="true"
RUN_MIGRATIONS="true"
SEED_ON_EMPTY="false"
DB_WAIT_TIMEOUT_MS="60000"
HEALTHCHECK_TIMEOUT_MS="5000"
