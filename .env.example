DATABASE_URL="postgresql://crm:crm@127.0.0.1:54329/ai_agent_crm?schema=public"
APP_BASE_URL="http://localhost:3000"
ALLOW_INSECURE_APP_BASE_URL="false"
REDIS_URL="redis://redis:6379"
JOB_EXECUTOR="inline"
JOB_QUEUE_NAME="crm:jobs"
JOB_DEAD_LETTER_QUEUE_NAME="crm:jobs:dead"
JOB_MAX_ATTEMPTS="3"
JOB_WORKER_POLL_MS="2000"
WORKFLOW_AUTOMATION_ENABLED="false"
EMAIL_SYNC_INTERVAL_MS="300000"
EMAIL_SYNC_LIMIT="25"
EMAIL_SYNC_USER_ID="user-admin"
EMAIL_SEND_CLAIM_TIMEOUT_MS="900000"
MAIL_CONNECT_TIMEOUT_MS="15000"
MAIL_RESPONSE_TIMEOUT_MS="30000"
MAIL_FETCH_RESPONSE_TIMEOUT_MS="60000"
MAIL_IMAP_FETCH_BYTES="262144"
MAIL_POP3_FETCH_MODE="retr"
MAIL_POP3_TOP_LINES="500"
AI_PROVIDER="openai-compatible"
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_MODEL="gpt-4.1-mini"
AI_TIMEOUT_MS="10000"
EMAIL_DELIVERY_MODE="live"
EMAIL_CONFIG_SECRET="replace-with-at-least-32-random-characters"
EMAIL_OAUTH_STATE_SECRET="replace-with-at-least-32-random-characters"
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET=""
