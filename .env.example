DATABASE_URL="postgresql://postgres@127.0.0.1:54329/ai_agent_crm?schema=public"
APP_BASE_URL="http://localhost:3000"
ALLOW_INSECURE_APP_BASE_URL="false"
REDIS_URL="redis://redis:6379"
JOB_EXECUTOR="inline"
JOB_QUEUE_NAME="crm:jobs"
JOB_DEAD_LETTER_QUEUE_NAME="crm:jobs:dead"
JOB_MAX_ATTEMPTS="3"
JOB_WORKER_POLL_MS="2000"
AI_PROVIDER="openai-compatible"
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_MODEL="gpt-4.1-mini"
AI_TIMEOUT_MS="10000"
ALLOW_PRIVATE_WEBHOOK_URLS="false"
WAIT_FOR_DATABASE="true"
RUN_MIGRATIONS="true"
SEED_ON_EMPTY="false"
DB_WAIT_TIMEOUT_MS="60000"
HEALTHCHECK_TIMEOUT_MS="5000"
BACKUP_DIR="backups"
DB_MAINTENANCE_MODE="auto"
SKIP_ENV_VALIDATION="false"
