GMAIL_OAUTH_TOKEN_URL="https://oauth2.googleapis.com/token"
GMAIL_OAUTH_SCOPE="https://mail.google.com/"
OUTLOOK_OAUTH_CLIENT_ID=""
OUTLOOK_OAUTH_CLIENT_SECRET=""
