generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               User[]
  teams               Team[]
  roles               Role[]
  objectDefinitions   ObjectDefinition[]
  fieldDefinitions    FieldDefinition[]
  relationDefinitions RelationDefinition[]
  records             CrmRecord[]
  pipelines           Pipeline[]
  activities          Activity[]
  auditLogs           AuditLog[]
  savedViews          SavedView[]
  importJobs          ImportJob[]
  importPresets       ImportPreset[]
  apiKeys             ApiKey[]
  webhooks            WebhookEndpoint[]
  webhookDeliveries   WebhookDelivery[]
  notificationChannels NotificationChannel[]
  emailAccounts       EmailAccount[]
  emailThreads        EmailThread[]
  emailThreadStates   EmailThreadState[]
  emailMessages       EmailMessage[]
  emailSignatures     EmailSignature[]
  knowledgeArticles   KnowledgeArticle[]
  knowledgeVectorSettings KnowledgeVectorSettings?
  knowledgeEmbeddingChunks KnowledgeEmbeddingChunk[]
  talkMessages        TalkMessage[]
  emailAiSettings     EmailAiSettings?
  emailSyncSettings   EmailSyncSettings?
  smartReminderSettings SmartReminderSettings?
  customerLevelSettings CustomerLevelSettings?
  smartReminders      SmartReminder[]
  smartReminderRuns   SmartReminderRun[]
  poolSettings        CrmPoolSettings?
  mediaAssets         MediaAsset[]
  recordChangeRequests RecordChangeRequest[]
  workflowDefinitions WorkflowDefinition[]
  workflowRuns        WorkflowRun[]
  workflowActionApprovals WorkflowActionApproval[]
}

model User {
  id                  String               @id @default(cuid())
  workspaceId         String
  email               String
  name                String
  passwordHash        String
  roleId              String?
  teamId              String?
  emailListDisplayMode String              @default("thread")
  active              Boolean              @default(true)
  disabledAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  workspace           Workspace            @relation(fields: [workspaceId], references: [id])
  role                Role?                @relation(fields: [roleId], references: [id])
  team                Team?                @relation(fields: [teamId], references: [id])
  sessions            Session[]
  passwordSetupTokens PasswordSetupToken[]
  apiKeys             ApiKey[]
  webhooksCreated     WebhookEndpoint[]
  notificationChannelsCreated NotificationChannel[]
  emailThreadStates   EmailThreadState[]
  emailSignaturesCreated EmailSignature[]
  mediaAssetsCreated  MediaAsset[]
  smartReminders      SmartReminder[]
  smartReminderRuns   SmartReminderRun[]

  @@unique([workspaceId, email])
  @@index([workspaceId, teamId])
  @@index([workspaceId, roleId])
  @@index([workspaceId, active])
}

model Team {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  users       User[]

  @@index([workspaceId, name])
}

model Role {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  permissions String[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  users       User[]

  @@index([workspaceId, name])
}

model ObjectDefinition {
  id          String            @id @default(cuid())
  workspaceId String
  key         String
  label       String
  pluralLabel String
  description String?
  icon        String?
  isSystem    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  fields      FieldDefinition[]
  views       SavedView[]

  @@unique([workspaceId, key])
  @@index([workspaceId, isSystem, createdAt])
}

model FieldDefinition {
  id                 String           @id @default(cuid())
  workspaceId        String
  objectDefinitionId String
  key                String
  label              String
  type               String
  required           Boolean          @default(false)
  unique             Boolean          @default(false)
  options            Json?
  defaultValue       Json?
  isSystem           Boolean          @default(false)
  position           Int              @default(0)
  workspace          Workspace        @relation(fields: [workspaceId], references: [id])
  objectDefinition   ObjectDefinition @relation(fields: [objectDefinitionId], references: [id])

  @@unique([objectDefinitionId, key])
  @@index([workspaceId, objectDefinitionId, position])
  @@index([workspaceId, type])
}

model RelationDefinition {
  id            String    @id @default(cuid())
  workspaceId   String
  fromObjectKey String
  toObjectKey   String
  key           String
  label         String
  cardinality   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, key])
  @@index([workspaceId, fromObjectKey])
  @@index([workspaceId, toObjectKey])
}

model CrmRecord {
  id          String     @id @default(cuid())
  workspaceId String
  objectKey   String
  title       String
  stageKey    String?
  ownerId     String?
  data        Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  activities  Activity[]
  smartReminders SmartReminder[]

  @@index([workspaceId, objectKey])
  @@index([workspaceId, objectKey, updatedAt])
  @@index([workspaceId, objectKey, ownerId])
  @@index([workspaceId, objectKey, stageKey])
  @@index([workspaceId, ownerId])
}

model Pipeline {
  id          String    @id @default(cuid())
  workspaceId String
  objectKey   String
  name        String
  isDefault   Boolean   @default(false)
  stages      Json
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, objectKey])
  @@index([workspaceId, objectKey, isDefault])
}

model Activity {
  id          String     @id @default(cuid())
  workspaceId String
  recordId    String?
  type        String
  title       String
  body        String?
  actorId     String?
  dueAt       DateTime?
  completedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  record      CrmRecord? @relation(fields: [recordId], references: [id])

  @@index([workspaceId, recordId, createdAt])
  @@index([workspaceId, type, completedAt, dueAt])
  @@index([workspaceId, type, archivedAt])
  @@index([workspaceId, actorId, createdAt])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  objectKey   String?
  summary     String
  details     Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, objectKey, createdAt])
  @@index([workspaceId, actorId, createdAt])
  @@index([workspaceId, action, createdAt])
}

model SavedView {
  id                 String           @id @default(cuid())
  workspaceId        String
  objectDefinitionId String
  name               String
  columns            String[]
  filters            Json?
  sort               Json?
  isDefault          Boolean          @default(false)
  workspace          Workspace        @relation(fields: [workspaceId], references: [id])
  objectDefinition   ObjectDefinition @relation(fields: [objectDefinitionId], references: [id])

  @@index([workspaceId, objectDefinitionId, isDefault])
  @@index([workspaceId, objectDefinitionId, name])
}

model CrmPoolSettings {
  workspaceId             String    @id
  enabled                 Boolean   @default(true)
  objectKeys              String[]
  privateLimit            Int       @default(100)
  autoReclaimEnabled      Boolean   @default(true)
  autoReclaimDays         Int       @default(30)
  levelRules              Json      @default("[{\"level\":\"A\",\"enabled\":true,\"privateLimit\":20,\"autoReclaimDays\":60},{\"level\":\"B\",\"enabled\":true,\"privateLimit\":40,\"autoReclaimDays\":45},{\"level\":\"C\",\"enabled\":true,\"privateLimit\":80,\"autoReclaimDays\":30},{\"level\":\"D\",\"enabled\":true,\"privateLimit\":100,\"autoReclaimDays\":14},{\"level\":\"unrated\",\"enabled\":true,\"privateLimit\":100,\"autoReclaimDays\":21}]")
  lastAutoReclaimAt       DateTime?
  lastAutoReclaimCount    Int       @default(0)
  updatedAt               DateTime  @updatedAt
  workspace               Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model SmartReminderSettings {
  workspaceId       String    @id
  enabled           Boolean   @default(true)
  dailyAt           String    @default("08:30")
  maxPerUser        Int       @default(10)
  objectKeys        String[]  @default(["contacts", "companies", "deals"])
  notifyCreated     Boolean   @default(false)
  notifyDailyDigest Boolean   @default(false)
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CustomerLevelSettings {
  workspaceId String    @id
  enabled     Boolean   @default(true)
  levels      Json
  rules       Json
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model SmartReminder {
  id                  String     @id @default(cuid())
  workspaceId          String
  userId               String
  objectKey            String?
  recordId             String?
  kind                 String
  priority             String
  title                String
  body                 String?
  actionLabel          String?
  dueAt                DateTime?
  status               String     @default("open")
  snoozedUntil         DateTime?
  sources              Json?
  score                Float      @default(0)
  idempotencyKey       String
  generatedByAgentKey  String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  completedAt          DateTime?
  dismissedAt          DateTime?
  workspace            Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  record               CrmRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId, idempotencyKey])
  @@index([workspaceId, userId, status, dueAt])
  @@index([workspaceId, objectKey, recordId])
  @@index([workspaceId, createdAt])
}

model SmartReminderRun {
  id             String    @id @default(cuid())
  workspaceId    String
  userId         String?
  status         String
  scope          Json
  generatedCount Int       @default(0)
  fallback       Boolean   @default(false)
  agentKey       String?
  provider       String?
  errorMessage   String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMs     Int?
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, userId, startedAt])
  @@index([workspaceId, status, startedAt])
}

model RecordChangeRequest {
  id            String    @id @default(cuid())
  workspaceId   String
  objectKey     String
  recordId      String
  action        String
  status        String    @default("pending")
  reason        String
  requestedById String
  reviewedById  String?
  reviewNote    String?
  patch         Json?
  recordTitle   String
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, objectKey, recordId])
  @@index([workspaceId, requestedById, createdAt])
}

model WorkflowDefinition {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  description   String?
  goal          String
  status        String    @default("draft")
  trigger       Json
  conditions    Json
  actions       Json
  graph         Json?
  createdById   String
  version       Int       @default(1)
  lastRunAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs          WorkflowRun[]
  approvals     WorkflowActionApproval[]

  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, createdById, updatedAt])
}

model WorkflowRun {
  id            String    @id @default(cuid())
  workspaceId   String
  workflowId    String
  status        String
  triggerEvent  String
  triggerData   Json
  idempotencyKey String
  conditionResults Json?
  actionResults Json?
  nodeResults   Json?
  errorMessage  String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  durationMs    Int?
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow      WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approvals     WorkflowActionApproval[]

  @@unique([workspaceId, workflowId, idempotencyKey])
  @@index([workspaceId, workflowId, startedAt])
  @@index([workspaceId, status, startedAt])
}

model WorkflowActionApproval {
  id            String    @id @default(cuid())
  workspaceId   String
  workflowId    String
  runId         String?
  actionKey     String
  actionType    String
  status        String    @default("pending")
  summary       String
  payload       Json
  requestedById String
  reviewedById  String?
  reviewNote    String?
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow      WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  run           WorkflowRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, workflowId, createdAt])
  @@index([workspaceId, requestedById, createdAt])
}

model ImportJob {
  id            String    @id @default(cuid())
  workspaceId   String
  objectKey     String
  status        String
  strategy      String
  totalRows     Int       @default(0)
  createdCount  Int       @default(0)
  errorCount    Int       @default(0)
  aborted       Boolean   @default(false)
  errorMessage  String?
  preview       Json?
  result        Json?
  sourcePayload Json?
  requestedById String?
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  workspace     Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, objectKey, createdAt])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, requestedById, createdAt])
}

model ImportPreset {
  id          String    @id @default(cuid())
  workspaceId String
  objectKey   String
  name        String
  strategy    String
  mapping     Json?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, objectKey, name])
  @@index([workspaceId, objectKey, updatedAt])
  @@index([workspaceId, createdById, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model PasswordSetupToken {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  tokenHash   String    @unique
  purpose     String
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, purpose, expiresAt])
  @@index([expiresAt, usedAt])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  permissions String[]
  createdById String
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, revokedAt])
  @@index([workspaceId, tokenPrefix])
  @@index([createdById, createdAt])
}

model WebhookEndpoint {
  id              String            @id @default(cuid())
  workspaceId     String
  name            String
  url             String
  events          String[]
  secret          String
  secretPrefix    String
  active          Boolean           @default(true)
  createdById     String
  lastDeliveredAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  createdBy       User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  deliveries      WebhookDelivery[]

  @@index([workspaceId, active, createdAt])
  @@index([workspaceId, createdAt])
  @@index([createdById, createdAt])
}

model WebhookDelivery {
  id             String           @id @default(cuid())
  workspaceId    String
  webhookId      String
  event          String
  status         String
  attempts       Int              @default(1)
  requestBody    Json
  responseStatus Int?
  responseBody   String?
  errorMessage   String?
  createdAt      DateTime         @default(now())
  deliveredAt    DateTime?
  workspace      Workspace        @relation(fields: [workspaceId], references: [id])
  webhook        WebhookEndpoint  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([workspaceId, webhookId, createdAt])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, event, createdAt])
}

model NotificationChannel {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  type            String
  events          String[]
  config          Json
  active          Boolean   @default(true)
  createdById     String
  lastNotifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  createdBy       User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, active, type, createdAt])
  @@index([workspaceId, createdAt])
  @@index([createdById, createdAt])
}

model EmailAccount {
  id            String         @id @default(cuid())
  workspaceId   String
  name          String
  emailAddress  String
  provider      String
  status        String         @default("draft")
  syncEnabled   Boolean        @default(false)
  sendEnabled   Boolean        @default(false)
  encryptedConnectionConfig String?
  lastConnectionError String?
  createdById   String
  lastSyncedAt  DateTime?
  lastSyncStatus String?
  lastSyncStartedAt DateTime?
  lastSyncFinishedAt DateTime?
  lastSyncScannedCount Int @default(0)
  lastSyncImportedCount Int @default(0)
  lastSyncSkippedDuplicateCount Int @default(0)
  lastSyncError String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspace     Workspace      @relation(fields: [workspaceId], references: [id])
  threads       EmailThread[]
  messages      EmailMessage[]
  signatures    EmailSignature[]

  @@unique([workspaceId, emailAddress])
  @@index([workspaceId, status])
  @@index([workspaceId, provider])
  @@index([workspaceId, createdById])
}

model EmailSignature {
  id          String        @id @default(cuid())
  workspaceId String
  accountId   String?
  name        String
  bodyText    String
  bodyHtml    String?
  isDefault   Boolean       @default(false)
  active      Boolean       @default(true)
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account     EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdBy   User          @relation(fields: [createdById], references: [id])

  @@index([workspaceId, accountId, active])
  @@index([workspaceId, isDefault])
  @@index([workspaceId, createdById])
}

model EmailThread {
  id                String         @id @default(cuid())
  workspaceId       String
  accountId         String
  subject           String
  participantEmails String[]
  recordId          String?
  summary           String?
  summaryUpdatedAt  DateTime?
  aiAnalysis        String?
  aiAnalysisSources Json?
  aiAnalysisUpdatedAt DateTime?
  lastMessageAt     DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  workspace         Workspace      @relation(fields: [workspaceId], references: [id])
  account           EmailAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages          EmailMessage[]
  states            EmailThreadState[]

  @@index([workspaceId, accountId, updatedAt])
  @@index([workspaceId, recordId, updatedAt])
  @@index([workspaceId, lastMessageAt])
}

model EmailThreadState {
  id             String      @id @default(cuid())
  workspaceId    String
  threadId       String
  userId         String
  archived       Boolean     @default(false)
  category       String?
  deleted        Boolean     @default(false)
  important      Boolean     @default(false)
  labels         String[]    @default([])
  read           Boolean     @default(false)
  snoozedUntil   DateTime?
  starred        Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  workspace      Workspace   @relation(fields: [workspaceId], references: [id])
  thread         EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, threadId, userId])
  @@index([workspaceId, userId, archived])
  @@index([workspaceId, userId, deleted])
  @@index([workspaceId, userId, starred])
  @@index([workspaceId, userId, important])
  @@index([workspaceId, userId, snoozedUntil])
  @@index([workspaceId, userId, category])
}

model EmailMessage {
  id                String       @id @default(cuid())
  workspaceId       String
  threadId          String
  accountId         String
  direction         String
  status            String
  fromAddress       String
  toAddresses       String[]
  ccAddresses       String[]
  bccAddresses      String[]
  subject           String
  bodyText          String
  bodyHtml          String?
  attachments       Json?
  translatedBodyText String?
  translatedLocale   String?
  translatedSources  Json?
  translatedAt       DateTime?
  aiAssisted       Boolean      @default(false)
  aiPurpose        String?
  aiSourceMessageId String?
  aiSources        Json?
  aiGeneratedAt    DateTime?
  externalMessageId String?
  clientRequestId String?
  failureReason     String?
  sendAttemptedAt   DateTime?
  scheduledSendAt   DateTime?
  sentAt            DateTime?
  receivedAt        DateTime?
  trackingEnabled   Boolean      @default(false)
  trackingId        String?      @unique
  trackingEvents    Json?
  inboundMetadata   Json?
  groupSendMode     Boolean      @default(false)
  createdById       String?
  createdAt         DateTime     @default(now())
  workspace         Workspace    @relation(fields: [workspaceId], references: [id])
  thread            EmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  account           EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, accountId, externalMessageId])
  @@index([workspaceId, threadId, createdAt])
  @@index([workspaceId, accountId, createdAt])
  @@index([workspaceId, accountId, clientRequestId])
  @@index([workspaceId, status, sendAttemptedAt])
  @@index([workspaceId, status, scheduledSendAt])
  @@index([workspaceId, trackingId])
  @@index([workspaceId, direction, status, createdAt])
}

model KnowledgeArticle {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  body        String
  tags        String[]
  active      Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  embeddingChunks KnowledgeEmbeddingChunk[]

  @@index([workspaceId, active, updatedAt])
  @@index([workspaceId, createdById, createdAt])
}

model KnowledgeVectorSettings {
  workspaceId          String    @id
  enabled              Boolean   @default(false)
  providerProfileKey   String    @default("openai")
  embeddingModel       String    @default("text-embedding-3-small")
  dimensions           Int       @default(1536)
  chunkSizeChars       Int       @default(1200)
  chunkOverlapChars    Int       @default(200)
  topK                 Int       @default(5)
  similarityThreshold  Float     @default(0.25)
  updatedAt            DateTime  @updatedAt
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model KnowledgeEmbeddingChunk {
  id             String    @id @default(cuid())
  workspaceId    String
  articleId      String
  chunkIndex     Int
  chunkText      String
  embedding      Unsupported("vector")?
  embeddingModel String
  dimensions     Int
  status         String    @default("indexed")
  errorMessage   String?
  indexedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  article        KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, chunkIndex])
  @@index([workspaceId, articleId])
  @@index([workspaceId, status, updatedAt])
}

model TalkMessage {
  id                 String    @id @default(cuid())
  workspaceId        String
  targetType         String
  objectKey          String?
  recordId           String?
  threadId           String?
  role               String
  content            String
  sources            Json?
  knowledgeArticleId String?
  createdById        String
  createdAt          DateTime  @default(now())
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, targetType, objectKey, recordId, createdAt])
  @@index([workspaceId, targetType, threadId, createdAt])
  @@index([workspaceId, knowledgeArticleId])
  @@index([workspaceId, createdById, createdAt])
}

model MediaAsset {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  contentType   String
  size          Int
  contentBase64 String
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy     User      @relation(fields: [createdById], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, contentType])
}

model EmailAiSettings {
  workspaceId          String    @id
  features             Json
  agents               Json      @default("[]")
  encryptedProviderConfig String?
  defaultLocale        String    @default("zh-CN")
  requireSourceLinks   Boolean   @default(true)
  maxHistoryMessages   Int       @default(8)
  maxKnowledgeArticles Int       @default(5)
  maxContextChars      Int       @default(8000)
  updatedAt            DateTime  @updatedAt
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
}

model EmailSyncSettings {
  workspaceId      String    @id
  enabled          Boolean   @default(true)
  mode             String    @default("interval")
  intervalMinutes  Int       @default(5)
  dailyAt          String    @default("03:00")
  limit            Int       @default(25)
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
