COMPOSE_PROJECT_NAME=ai-agent-crm
CRM_IMAGE=ghcr.io/your-org/ai-agent-crm:latest
CRM_DATA_DIR=/opt/ai-agent-crm
APP_PORT=3000
APP_BASE_URL=https://crm.example.com
ALLOW_INSECURE_APP_BASE_URL=false

# Postgres is managed outside this Compose stack.
# For a separate Postgres container published as 5433:5432 on the VPS host,
# app containers should connect through host.docker.internal:5433.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5433
POSTGRES_DB=ai_agent_crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=replace-with-url-safe-database-password
DATABASE_URL=postgresql://crm:replace-with-url-safe-database-password@host.docker.internal:5433/ai_agent_crm?schema=public

RUN_MIGRATIONS=true
SEED_ON_EMPTY=false
DB_WAIT_TIMEOUT_MS=90000

JOB_QUEUE_NAME=crm:jobs
JOB_DEAD_LETTER_QUEUE_NAME=crm:jobs:dead
JOB_MAX_ATTEMPTS=3
JOB_WORKER_POLL_MS=2000

EMAIL_SYNC_INTERVAL_MS=300000
EMAIL_SYNC_LIMIT=25
EMAIL_SYNC_USER_ID=user-admin
EMAIL_SEND_CLAIM_TIMEOUT_MS=900000
EMAIL_DELIVERY_MODE=live
EMAIL_CONFIG_SECRET=replace-with-at-least-32-random-characters
EMAIL_OAUTH_STATE_SECRET=replace-with-at-least-32-random-characters

AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_MS=10000

GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GMAIL_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GMAIL_OAUTH_SCOPE=https://mail.google.com/

OUTLOOK_OAUTH_CLIENT_ID=
OUTLOOK_OAUTH_CLIENT_SECRET=
OUTLOOK_OAUTH_AUTH_URL=https://login.microsoftonline.com/common/oauth2/v2.0/authorize
OUTLOOK_OAUTH_TOKEN_URL=https://login.microsoftonline.com/common/oauth2/v2.0/token
OUTLOOK_OAUTH_SCOPE=https://graph.microsoft.com/Mail.ReadWrite https://graph.microsoft.com/Mail.Send offline_access
